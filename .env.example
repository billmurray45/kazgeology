# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
# Comma-separated. Required when DEBUG=False.
ALLOWED_HOSTS=kazgeology.kz,www.kazgeology.kz
# Comma-separated full origins (scheme + host). Needed for https admin/POST.
CSRF_TRUSTED_ORIGINS=https://kazgeology.kz,https://www.kazgeology.kz

# Security
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# Database (PostgreSQL)
DB_HOST=postgres
DB_NAME=kazgeology_db
DB_USER=kazgeology_user
DB_PASSWORD=change-me
DB_PORT=5432

# Email (SMTP / Gmail)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
